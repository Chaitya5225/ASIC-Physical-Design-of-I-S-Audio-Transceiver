library (i2s_tx) {
  comment                        : "";
  delay_model                    : table_lookup;
  simulation                     : false;
  capacitive_load_unit (1,pF);
  leakage_power_unit             : 1pW;
  current_unit                   : "1A";
  pulling_resistance_unit        : "1kohm";
  time_unit                      : "1ns";
  voltage_unit                   : "1v";
  library_features(report_delay_calculation);

  input_threshold_pct_rise : 50;
  input_threshold_pct_fall : 50;
  output_threshold_pct_rise : 50;
  output_threshold_pct_fall : 50;
  slew_lower_threshold_pct_rise : 20;
  slew_lower_threshold_pct_fall : 20;
  slew_upper_threshold_pct_rise : 80;
  slew_upper_threshold_pct_fall : 80;
  slew_derate_from_library : 1.0;


  nom_process                    : 1.0;
  nom_temperature                : 100.0;
  nom_voltage                    : 1.60;

  lu_table_template(template_1) {
    variable_1 : total_output_net_capacitance;
    index_1 ("0.00050,  0.00181,  0.00654,  0.02365,  0.08552,  0.30928,  1.11848");
  }
  type ("left_data") {
    base_type : array;
    data_type : bit;
    bit_width : 16;
    bit_from : 15;
    bit_to : 0;
  }
  type ("right_data") {
    base_type : array;
    data_type : bit;
    bit_width : 16;
    bit_from : 15;
    bit_to : 0;
  }

  cell ("i2s_tx") {
    pin("clk") {
      direction : input;
      capacitance : 0.0067;
    }
    pin("reset") {
      direction : input;
      capacitance : 0.0032;
      timing() {
        related_pin : "clk";
        timing_type : hold_rising;
	fall_constraint(scalar) {
          values("0.30887");
	}
      }
      timing() {
        related_pin : "clk";
        timing_type : setup_rising;
	fall_constraint(scalar) {
          values("-0.10140");
	}
      }
    }
    pin("sck") {
      direction : output;
      capacitance : 0.0005;
      timing() {
        related_pin : "clk";
        timing_type : rising_edge;
	cell_rise(template_1) {
          values("1.20005,1.20908,1.23435,1.30064,1.50129,2.20872,4.76282");
	}
	rise_transition(template_1) {
          values("0.03935,0.04590,0.06700,0.13830,0.40698,1.40360,4.99839");
	}
	cell_fall(template_1) {
          values("1.37135,1.37848,1.40067,1.45664,1.61305,2.14883,4.08093");
	}
	fall_transition(template_1) {
          values("0.03446,0.03978,0.05706,0.10980,0.30117,1.02137,3.64784");
	}
      }
    }
    pin("sd") {
      direction : output;
      capacitance : 0.0029;
    }
    pin("ws") {
      direction : output;
      capacitance : 0.0006;
    }
    bus("left_data") {
      bus_type : left_data;
      direction : input;
      capacitance : 0.0000;
    pin("left_data[15]") {
      direction : input;
      capacitance : 0.0032;
    }
    pin("left_data[14]") {
      direction : input;
      capacitance : 0.0030;
    }
    pin("left_data[13]") {
      direction : input;
      capacitance : 0.0029;
    }
    pin("left_data[12]") {
      direction : input;
      capacitance : 0.0026;
    }
    pin("left_data[11]") {
      direction : input;
      capacitance : 0.0032;
    }
    pin("left_data[10]") {
      direction : input;
      capacitance : 0.0034;
    }
    pin("left_data[9]") {
      direction : input;
      capacitance : 0.0036;
    }
    pin("left_data[8]") {
      direction : input;
      capacitance : 0.0026;
    }
    pin("left_data[7]") {
      direction : input;
      capacitance : 0.0027;
    }
    pin("left_data[6]") {
      direction : input;
      capacitance : 0.0038;
    }
    pin("left_data[5]") {
      direction : input;
      capacitance : 0.0027;
    }
    pin("left_data[4]") {
      direction : input;
      capacitance : 0.0032;
    }
    pin("left_data[3]") {
      direction : input;
      capacitance : 0.0032;
    }
    pin("left_data[2]") {
      direction : input;
      capacitance : 0.0028;
    }
    pin("left_data[1]") {
      direction : input;
      capacitance : 0.0027;
    }
    pin("left_data[0]") {
      direction : input;
      capacitance : 0.0029;
    }
    }
    bus("right_data") {
      bus_type : right_data;
      direction : input;
      capacitance : 0.0000;
    pin("right_data[15]") {
      direction : input;
      capacitance : 0.0029;
    }
    pin("right_data[14]") {
      direction : input;
      capacitance : 0.0026;
    }
    pin("right_data[13]") {
      direction : input;
      capacitance : 0.0032;
    }
    pin("right_data[12]") {
      direction : input;
      capacitance : 0.0030;
    }
    pin("right_data[11]") {
      direction : input;
      capacitance : 0.0036;
    }
    pin("right_data[10]") {
      direction : input;
      capacitance : 0.0031;
    }
    pin("right_data[9]") {
      direction : input;
      capacitance : 0.0030;
    }
    pin("right_data[8]") {
      direction : input;
      capacitance : 0.0031;
    }
    pin("right_data[7]") {
      direction : input;
      capacitance : 0.0026;
    }
    pin("right_data[6]") {
      direction : input;
      capacitance : 0.0038;
    }
    pin("right_data[5]") {
      direction : input;
      capacitance : 0.0028;
    }
    pin("right_data[4]") {
      direction : input;
      capacitance : 0.0032;
    }
    pin("right_data[3]") {
      direction : input;
      capacitance : 0.0027;
    }
    pin("right_data[2]") {
      direction : input;
      capacitance : 0.0027;
    }
    pin("right_data[1]") {
      direction : input;
      capacitance : 0.0032;
    }
    pin("right_data[0]") {
      direction : input;
      capacitance : 0.0030;
    }
    }
  }

}
